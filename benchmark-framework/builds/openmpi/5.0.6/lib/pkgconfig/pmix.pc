prefix=/home/sumeet/benchmark-framework/builds/openmpi/5.0.6
exec_prefix=${prefix}
libdir=${exec_prefix}/lib
includedir=${prefix}/include

Name: pmix
Description: Process Management Interface for Exascale (PMIx)
Version: 5.0.4
URL: https://pmix.org/
Libs: -L${libdir} -Wl,-rpath -Wl,${libdir} -Wl,--enable-new-dtags -lpmix -levent_core -levent_pthreads
Libs.private: 
Cflags: -I${includedir} -I${includedir}/pmix -I/usr/local/include
Requires: 
Requires.private: 
